# Copy to .env.local for local dev, and set the same keys in Vercel
# Project Settings -> Environment Variables for production/preview.

# --- Database (Neon Postgres) ---
DATABASE_URL="postgresql://...?sslmode=require"      # pooled connection
DIRECT_URL="postgresql://...?sslmode=require"         # direct connection, used by `prisma migrate`

# --- Auth (single admin account) ---
AUTH_SECRET="generate-with: openssl rand -base64 33"
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD_HASH="generate-with: npm run seed:admin"

# --- AI chatbot ---
GEMINI_API_KEY="get a free key at aistudio.google.com/api-keys"

# --- Image uploads (admin editor) ---
BLOB_READ_WRITE_TOKEN="from Vercel Blob store settings"

# --- Analytics ---
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_CLARITY_ID="xxxxxxxxxx"

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://ashunayak.com"
